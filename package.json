{
  "name": "commonwealth-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Commonwealth (CW) — a wealth-building operating system.",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm --workspace server run dev\" \"npm --workspace client run dev\"",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server start",
    "seed": "npm --workspace server run seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
